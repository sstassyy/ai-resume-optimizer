// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  resumes   Resume[]
  vacancies Vacancy[]
}

model Resume {
  id             String   @id @default(cuid())
  userId         String
  title          String
  contentJson    String? // JSON: structured resume content (name, experience, education, skills, contacts)
  sourceFileUrl  String? // relative path under uploads/ for the original uploaded file, if any
  createdAt      DateTime @default(now())
  version        Int      @default(1)
  parentResumeId String? // links an adapted resume back to the resume it was generated from
  vacancyId      String? // set only on adapted versions: the vacancy this version was adapted for
  adaptationId   String? // set only on versions created via confirming an adaptation: the Adaptation draft that produced it (for its ATS score)

  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent           Resume?     @relation("ResumeVersions", fields: [parentResumeId], references: [id])
  children         Resume[]    @relation("ResumeVersions")
  vacancy          Vacancy?    @relation(fields: [vacancyId], references: [id])
  sourceAdaptation Adaptation? @relation("ResumeSourceAdaptation", fields: [adaptationId], references: [id])

  analyses    Analysis[]
  adaptations Adaptation[] @relation("AdaptationOriginalResume")
}

model Vacancy {
  id                       String   @id @default(cuid())
  userId                   String
  sourceType               String // "text" | "file" | "url"
  rawText                  String // for "url" this is the extracted page text, not the link itself
  sourceUrl                String? // original link, only set when sourceType = "url"
  extractedRequirementsJson String? // JSON: AI-extracted must-have/nice-to-have requirements (Release 2+)
  createdAt                DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  analyses       Analysis[]
  adaptations    Adaptation[]
  adaptedResumes Resume[]
}

model Analysis {
  id                String   @id @default(cuid())
  resumeId          String
  vacancyId         String
  matchPercent      Int // overall score, average of categoryScoresJson
  categoryScoresJson String // JSON: { skills, experience, education } percentages 0-100
  matchedSkillsJson String // JSON array
  missingSkillsJson String // JSON array
  createdAt         DateTime @default(now())

  resume  Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  vacancy Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
}

model Adaptation {
  id                  String   @id @default(cuid())
  resumeId            String
  vacancyId           String
  adaptedContentJson  String // JSON: generated resume content
  diffJson            String? // JSON: before/after diff
  atsScore            Int?
  recommendationsJson String? // JSON array
  createdAt           DateTime @default(now())

  resume  Resume  @relation("AdaptationOriginalResume", fields: [resumeId], references: [id], onDelete: Cascade)
  vacancy Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  resultResumes Resume[] @relation("ResumeSourceAdaptation")
}
